{
  "functions": {
    "src/app.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "src/app.ts"
    }
  ],
  "crons": [
    {
      "path": "/cron/master",
      "schedule": "0 * * * *"
    },
    {
      "path": "/cron/process-messages",
      "schedule": "* * * * *"
    }
  ]
}

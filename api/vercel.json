{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    { "path": "/cron/master", "schedule": "0 * * * *" },
    { "path": "/cron/process-messages", "schedule": "* * * * *" }
  ]
}

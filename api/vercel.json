{
  "version": 2,
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "50mb", "memory": 1024, "maxDuration": 30 }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/app.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/cron/cleanup-pro-docs",
      "schedule": "50 10 * * *"
    },
    {
      "path": "/cron/monthly-reset",
      "schedule": "50 10 * * *"
    },
    {
      "path": "/cron/followup-cnpj",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/cron/followup-whatsapp-morning",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/cron/followup-whatsapp-evening",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/cron/inactive-engagement",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/cron/sdr-followup",
      "schedule": "*/30 8-21 * * *"
    }
  ]
}

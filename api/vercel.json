{
  "version": 2,
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "50mb", "memory": 1024, "maxDuration": 30 }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/app.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/cron/cleanup-pro-docs",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/cron/monthly-reset",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/cron/followup-cnpj",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/cron/followup-whatsapp",
      "schedule": "0 13 * * *"
    }
  ]
}

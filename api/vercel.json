{
  "version": 2,
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/app.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/cron/cleanup-pro-docs",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/cron/monthly-reset",
      "schedule": "0 3 * * *"
    }
  ]
}

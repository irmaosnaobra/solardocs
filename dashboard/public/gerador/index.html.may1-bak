        </div>
        <div class="field">
          <label>Taxa mínima / Fio B (R$)</label>
          <input type="number" id="f-taxamin" value="95" step="0.01">
        </div>

        <div class="toggle-group">
          <button id="btn-kwh" class="ativo" onclick="setModo('kwh')">Por consumo (kWh)</button>
          <button id="btn-placas" onclick="setModo('placas')">Por quantidade de placas</button>
        </div>

        <div class="field full" id="campo-consumo">
          <label>Consumo mensal (kWh)</label>
          <input type="number" id="f-consumo" placeholder="Ex: 600">
        </div>
        <div class="field full" id="campo-qtd" style="display:none;">
          <label>Quantidade de placas</label>
          <input type="number" id="f-qtd" placeholder="Ex: 8">
        </div>

        <div class="field full">
          <label class="chk-desc">
            <input type="checkbox" id="f-descmax">
            <span>💎 Aplicar desconto máximo (preço à vista mais agressivo)</span>
          </label>
        </div>

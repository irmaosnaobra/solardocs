// ============= SUPABASE =============
const SUPABASE_URL = 'https://ancecdfqfwlaujknizof.supabase.co';
const SUPABASE_KEY = 'sb_publishable_IK5RV-I0PlQNpb7-cXBQFg_-pSYscO6';

const supaHeaders = () => ({
  'apikey': SUPABASE_KEY,
  'Authorization': `Bearer ${SUPABASE_KEY}`,
  'Content-Type': 'application/json'
});

async function supaInsert(table, body) {
  const r = await fetch(`${SUPABASE_URL}/rest/v1/${table}`, {
    method: 'POST',
    headers: { ...supaHeaders(), 'Prefer': 'return=representation' },
    body: JSON.stringify(body)
  });
  if (!r.ok) throw new Error(await r.text());
  return r.json();
}

async function supaGet(query) {
  const r = await fetch(`${SUPABASE_URL}/rest/v1/${query}`, { headers: supaHeaders() });
  if (!r.ok) throw new Error(await r.text());
  return r.json();
}

async function supaRpc(fn, args) {
  const r = await fetch(`${SUPABASE_URL}/rest/v1/rpc/${fn}`, {
    method: 'POST',
    headers: supaHeaders(),
    body: JSON.stringify(args || {})
  });
  if (!r.ok) throw new Error(await r.text());
  return r.json();
}

async function salvarPropostaSupabase(d) {
  const cidade = (d.cidade || '').trim();
  const partes = cidade.split(',').map(s => s.trim()).filter(Boolean);
  const cidNome = partes[0] || null;
  const uf = partes[1] || null;

  const row = {
    dados: d,
    consultor_nome: d.consultor || null,
    cliente_nome: d.nome,
    cliente_cidade: cidNome,
    cliente_uf: uf,
    geracao_kwh: d.item.g,
    kwp: d.item.kwp,
    telhado: d.telhado || null,
    fase: d.fase || null,
    inversor: d.tab.inv,
    qtd_inversor: d.qtdInv,
    qtd_placas: d.item.n
  };
  const arr = await supaInsert('propostas', row);
  return arr[0].codigo;
}


// ============= UTILS =============
function fmt(n) {
  return Math.round(Number(n)).toLocaleString('pt-BR', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
  });
}

function fmtN(n) {
  return Math.round(n).toLocaleString('pt-BR');
}

function initials(nome) {
  const partes = nome.trim().split(/\s+/).filter(Boolean);
  if (partes.length === 0) return '??';
  if (partes.length === 1) return partes[0].substring(0,2).toUpperCase();
  return (partes[0][0] + partes[partes.length-1][0]).toUpperCase();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2600);
}

function showErro(msg) {
  const e = document.getElementById('erro');
  e.textContent = msg;
  e.classList.add('show');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function hideErro() {
  document.getElementById('erro').classList.remove('show');
}

// ============= PREFS (localStorage) =============
const PREFS_KEY = 'irmaos-na-obra-prefs-v1';
function salvarPrefs() {
  try {
    const prefs = {
      consultor: document.getElementById('f-consultor').value.trim(),
      tarifa: document.getElementById('f-tarifa').value,
      taxaMin: document.getElementById('f-taxamin').value
    };
    localStorage.setItem(PREFS_KEY, JSON.stringify(prefs));
  } catch (e) {}
}
function carregarPrefs() {
  try {
    const raw = localStorage.getItem(PREFS_KEY);
    if (!raw) return;
    const p = JSON.parse(raw);
    if (p.consultor) document.getElementById('f-consultor').value = p.consultor;
    if (p.tarifa)    document.getElementById('f-tarifa').value = p.tarifa;
    if (p.taxaMin)   document.getElementById('f-taxamin').value = p.taxaMin;
  } catch (e) {}
}
window.addEventListener('DOMContentLoaded', carregarPrefs);

// ============= DISTÂNCIA DE UBERLÂNDIA (auto) =============
// Geocodifica via Nominatim (OSM) e calcula distância haversine + fator rodoviário.
// Coordenadas de Uberlândia/MG centro:
const UBERLANDIA = { lat: -18.9189, lng: -48.2773 };
const ROAD_FACTOR = 1.20; // converte distância em linha reta para aproximação rodoviária
const DIST_CACHE_KEY = 'irmaos-dist-cache-v1';

function haversineKm(lat1, lng1, lat2, lng2) {
  const R = 6371;
  const toRad = d => d * Math.PI / 180;
  const dLat = toRad(lat2 - lat1);
  const dLng = toRad(lng2 - lng1);
  const a = Math.sin(dLat/2)**2 +
            Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
            Math.sin(dLng/2)**2;
  return 2 * R * Math.asin(Math.sqrt(a));
}

function distCacheGet(cidade, uf) {
  try {
    const c = JSON.parse(localStorage.getItem(DIST_CACHE_KEY) || '{}');
    return c[`${cidade.toLowerCase()}|${(uf||'').toLowerCase()}`];
  } catch (e) { return undefined; }
}
function distCacheSet(cidade, uf, km) {
  try {
    const c = JSON.parse(localStorage.getItem(DIST_CACHE_KEY) || '{}');
    c[`${cidade.toLowerCase()}|${(uf||'').toLowerCase()}`] = km;
    localStorage.setItem(DIST_CACHE_KEY, JSON.stringify(c));
  } catch (e) {}
}

async function geocodeCidade(cidade, uf) {
  cidade = (cidade || '').trim();
  uf = (uf || '').trim();
  if (!cidade) return null;

  const cached = distCacheGet(cidade, uf);
  if (typeof cached === 'number') return cached;

  const q = uf ? `${cidade}, ${uf}, Brasil` : `${cidade}, Brasil`;
  const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&countrycodes=br&q=${encodeURIComponent(q)}`;

  const res = await fetch(url, { headers: { 'Accept-Language': 'pt-BR' } });
  if (!res.ok) throw new Error('falha na busca');
  const data = await res.json();
  if (!data || !data.length) return null;

  const km = Math.round(
    haversineKm(UBERLANDIA.lat, UBERLANDIA.lng,
                parseFloat(data[0].lat), parseFloat(data[0].lon)) * ROAD_FACTOR
  );
  distCacheSet(cidade, uf, km);
  return km;
}

function acrescimoPorKm(km) {
  if (!km || km <= 0) return 0;
  if (km >= 350) return 750;
  if (km >= 250) return 500;
  return 0;
}

let rastreioPromise = null;
async function rastrearDistancia({ silent = false } = {}) {
  const cidade = document.getElementById('f-cidade').value.trim();
  const uf = document.getElementById('f-uf').value;
  const distInput = document.getElementById('f-distancia');
  const status = document.getElementById('dist-status');

  if (!cidade) { if (!silent) status.textContent = ''; return null; }

  if (!silent) status.textContent = '🔍 Buscando distância…';
  try {
    const km = await geocodeCidade(cidade, uf);
    if (km == null) {
      if (!silent) status.textContent = '⚠️ Cidade não localizada. Preencha a distância manualmente.';
      return null;
    }
    distInput.value = km;
    const acresc = acrescimoPorKm(km);
    if (acresc > 0) {
      status.textContent = `📍 ~${km} km de Uberlândia · acréscimo de R$ ${acresc.toLocaleString('pt-BR')} aplicado automaticamente`;
    } else {
      status.textContent = `📍 ~${km} km de Uberlândia · sem acréscimo (abaixo de 250 km)`;
    }
    return km;
  } catch (e) {
    if (!silent) status.textContent = '⚠️ Erro na busca. Preencha a distância manualmente.';
    return null;
  }
}

window.addEventListener('DOMContentLoaded', () => {
  const cidadeEl = document.getElementById('f-cidade');
  const ufEl = document.getElementById('f-uf');
  const distEl = document.getElementById('f-distancia');

  const trigger = () => {
    // Se vendedor já digitou distância manualmente, não sobrescreve.
    if (distEl.value && parseFloat(distEl.value) > 0) return;
    rastreioPromise = rastrearDistancia();
  };

  cidadeEl.addEventListener('blur', trigger);
  ufEl.addEventListener('change', trigger);

  // Se vendedor limpa distância, libera para nova busca automática.
  distEl.addEventListener('input', () => {
    if (!distEl.value) document.getElementById('dist-status').textContent = '';
  });
});

// ============= MODO =============
function setModo(m) {
  modo = m;
  document.getElementById('btn-kwh').classList.toggle('ativo', m === 'kwh');
  document.getElementById('btn-placas').classList.toggle('ativo', m === 'placas');
  document.getElementById('campo-consumo').style.display = m === 'kwh' ? '' : 'none';
  document.getElementById('campo-qtd').style.display = m === 'placas' ? '' : 'none';
}

// ============= GERAR =============
async function gerar() {
  hideErro();

  const nome = document.getElementById('f-nome').value.trim();
  const cidadeNome = document.getElementById('f-cidade').value.trim();
  const uf = document.getElementById('f-uf').value;
  const cidade = [cidadeNome, uf].filter(Boolean).join(', ');

  // Garante que a busca de distância (se em andamento) finalize antes de calcular preço.
  if (rastreioPromise) { try { await rastreioPromise; } catch (e) {} rastreioPromise = null; }
  // Se ainda não há distância e cidade está preenchida, tenta uma busca síncrona.
  if (!document.getElementById('f-distancia').value && cidadeNome) {
    try { await rastrearDistancia(); } catch (e) {}
  }

  const distanciaKm = parseFloat(document.getElementById('f-distancia').value) || 0;
  const telhado = document.getElementById('f-telhado').value;
  const fase = document.getElementById('f-fase').value;
  const linha = document.getElementById('f-linha').value;
  const tarifa = parseFloat(document.getElementById('f-tarifa').value) || 1.09;
  const taxaMin = parseFloat(document.getElementById('f-taxamin').value) || 95;
  const consultor = document.getElementById('f-consultor').value.trim();

  if (!consultor) return showErro('Selecione o consultor responsável.');
  if (!nome) return showErro('Informe o nome do cliente.');
  if (!linha) return showErro('Selecione a linha de equipamento.');

  salvarPrefs();

  const tab = TABELAS[linha];
  let item;

  if (modo === 'kwh') {
    const consumo = parseFloat(document.getElementById('f-consumo').value);
    if (!consumo || consumo <= 0) return showErro('Informe o consumo mensal em kWh.');
    item = tab.rows.find(r => r.g >= consumo) || tab.rows[tab.rows.length - 1];
  } else {
    const qtd = parseFloat(document.getElementById('f-qtd').value);
    if (!qtd || qtd <= 0) return showErro('Informe a quantidade de placas.');
    item = tab.rows.reduce((a, b) =>
      Math.abs(b.n - qtd) < Math.abs(a.n - qtd) ? b : a
    );
  }

  // Preços
  // Acréscimo automático por distância de Uberlândia/MG:
  //   >= 350 km → +R$ 750,00
  //   >= 250 km → +R$ 500,00
  const acrescDist = acrescimoPorKm(distanciaKm);
  const usarDescMax = document.getElementById('f-descmax').checked;
  const precoVista = (usarDescMax ? item.descMax : item.pVista) + acrescDist;
  const precoOrcamento = Math.ceil((item.pOrc + acrescDist) / 100) * 100;

  // Parcelas em cima do preço à vista
  const parc10x = precoVista * 1.11 / 10;
  const parc18x = precoVista * 1.19 / 18;

  // Cálculos
  const areaReal = (item.kwp * 1000 / tab.pot * 2.1).toFixed(1);
  const economia = Math.max(Math.round(item.g * tarifa - taxaMin), 0);
  const payback = (precoVista / Math.max(economia * 12, 1)).toFixed(1);
  const economia25 = economia * 12 * 25;
  const pbPct = Math.min(Math.round((parseFloat(payback) / 25) * 100), 100);

  // Inversores (vem da própria tabela)
  const isString = tab.inv.includes('SAJ') || tab.inv.includes('Sungrow');
  const qtdInv = item.invs;
  const garInv = isString ? '10' : '15';

  // Guardar para o WhatsApp / link
  dadosAtual = {
    dataEmissao: new Date().toISOString(),
    nome, cidade, distanciaKm, telhado, fase,
    item: { n: item.n, g: item.g, kwp: item.kwp, invs: item.invs },
    tab: { inv: tab.inv, mod: tab.mod, pot: tab.pot },
    areaReal, economia, economia25, payback,
    qtdInv, garInv,
    precoVista, precoOrcamento, parc10x, parc18x, usarDescMax,
    acrescDist,
    consultor
  };

  renderProposta(dadosAtual, false);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ============= RENDER TELA 2 =============
function renderProposta(d, viaLink) {
  const meses = ['janeiro','fevereiro','março','abril','maio','junho','julho','agosto','setembro','outubro','novembro','dezembro'];
  const dataEmissao = d.dataEmissao ? new Date(d.dataEmissao) : new Date();

  document.getElementById('prop-data').textContent =
    `Gerada em ${meses[dataEmissao.getMonth()]} de ${dataEmissao.getFullYear()} · Válida por 7 dias`;

  document.getElementById('avatar').textContent = initials(d.nome);
  document.getElementById('cli-nome').textContent = d.nome;
  const metaPartes = [];
  if (d.cidade) metaPartes.push(d.cidade);
  if (d.fase) metaPartes.push(d.fase);
  if (d.telhado) metaPartes.push(`Telhado ${d.telhado}`);
  document.getElementById('cli-meta').textContent = metaPartes.join(' · ');

  document.getElementById('m-pot').textContent = d.item.kwp.toFixed(1);
  document.getElementById('m-ger').textContent = fmtN(d.item.g);
  document.getElementById('m-area').textContent = d.areaReal;

  document.getElementById('e-mod').textContent = `${d.item.n}x ${d.tab.mod}`;
  document.getElementById('e-inv').textContent = `${d.qtdInv}x ${d.tab.inv}`;
  document.getElementById('e-pot').textContent = `${d.tab.pot}W / módulo`;

  document.getElementById('g-inv').textContent = `${d.garInv} anos`;

  document.getElementById('r-mensal').textContent = `~ R$ ${fmtN(d.economia)}/mês`;
  document.getElementById('r-25').textContent = `~ R$ ${fmtN(d.economia25)}`;
  document.getElementById('r-pb').textContent = `~ ${d.payback} anos`;
  const pbPct = Math.min(Math.round((parseFloat(d.payback) / 25) * 100), 100);
  document.getElementById('pb-fill').style.width = pbPct + '%';
  document.getElementById('pb-leg').textContent = `${d.payback} anos de payback em 25 anos de geração`;

  document.getElementById('p-total').textContent = `R$ ${fmt(d.precoOrcamento)}`;
  document.getElementById('p-vista').textContent = `R$ ${fmt(d.precoVista)}`;

  document.getElementById('parc-10').textContent = `R$ ${fmt(d.parc10x)}`;
  document.getElementById('parc-18').textContent = `R$ ${fmt(d.parc18x)}`;

  // Rodapé do consultor: só aparece pro vendedor (NÃO pro cliente que abre o link)
  const cardCons = document.getElementById('card-consultor');
  if (!viaLink && d.consultor) {
    cardCons.style.display = '';
    document.getElementById('rodape-consultor-nome').textContent = d.consultor;
    document.getElementById('rodape-consultor-tel').style.display = 'none';
  } else {
    cardCons.style.display = 'none';
  }

  // Modo "via link" (cliente abrindo) — esconde TUDO exceto o orçamento
  document.querySelector('.acoes').style.display = viaLink ? 'none' : '';
  document.getElementById('btn-nova').style.display = viaLink ? 'none' : '';

  // Trocar telas
  document.getElementById('formSection').style.display = 'none';
  document.getElementById('propostaSection').style.display = '';
}

// ============= NOVA =============
function novaProposta() {
  // Limpa ?p= se estiver na URL
  if (window.location.search) {
    history.replaceState(null, '', window.location.pathname);
  }
  document.getElementById('propostaSection').style.display = 'none';
  document.getElementById('formSection').style.display = '';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function novoCliente() {
  // Limpa ?p= se estiver na URL
  if (window.location.search) {
    history.replaceState(null, '', window.location.pathname);
  }
  // Limpa só os dados do cliente — mantém consultor, tarifa, taxa mínima
  document.getElementById('f-nome').value = '';
  document.getElementById('f-cidade').value = '';
  document.getElementById('f-uf').value = '';
  document.getElementById('f-distancia').value = '';
  const distStatus = document.getElementById('dist-status');
  if (distStatus) distStatus.textContent = '';
  document.getElementById('f-telhado').value = '';
  document.getElementById('f-fase').value = '';
  document.getElementById('f-linha').value = '';
  document.getElementById('f-consumo').value = '';
  document.getElementById('f-qtd').value = '';
  document.getElementById('f-descmax').checked = false;
  hideErro();
  dadosAtual = null;

  document.getElementById('propostaSection').style.display = 'none';
  document.getElementById('expiradoSection').style.display = 'none';
  document.getElementById('historicoSection').style.display = 'none';
  document.getElementById('formSection').style.display = '';
  window.scrollTo({ top: 0, behavior: 'smooth' });
  document.getElementById('f-nome').focus();
}

// ============= LINK COMPARTILHÁVEL =============
async function garantirCodigo() {
  if (dadosAtual.codigo) return dadosAtual.codigo;
  dadosAtual.codigo = await salvarPropostaSupabase(dadosAtual);
  return dadosAtual.codigo;
}

async function gerarLinkProposta() {
  if (!dadosAtual) return;
  showToast('⏳ Gerando link...');
  try {
    const codigo = await garantirCodigo();
    supaRpc('marcar_enviado_link', { p_codigo: codigo }).catch(e => console.error(e));

    const baseUrl = window.location.origin + window.location.pathname;
    const link = `${baseUrl}?p=${codigo}`;

    if (navigator.clipboard && navigator.clipboard.writeText) {
      try {
        await navigator.clipboard.writeText(link);
        showToast(`🔗 Link ${codigo} copiado!`);
      } catch (e) {
        fallbackCopy(link);
      }
    } else {
      fallbackCopy(link);
    }
  } catch (e) {
    console.error(e);
    showToast('❌ Erro ao gerar link');
  }
}

function ehVendedor() {
  try {
    const raw = localStorage.getItem(PREFS_KEY);
    if (!raw) return false;
    const p = JSON.parse(raw);
    return !!(p.consultor && p.consultor.trim().length > 0);
  } catch { return false; }
}

async function carregarDeURL() {
  try {
    const url = new URL(window.location.href);
    const p = url.searchParams.get('p');
    if (!p) return;

    let d, dataEmissao, codigoSupabase = null;
    const vendedor = ehVendedor();

    if (/^\d{6,12}$/.test(p)) {
      // Código curto — busca no Supabase
      const arr = await supaGet(`propostas?codigo=eq.${encodeURIComponent(p)}&select=*&limit=1`);
      if (!arr || arr.length === 0) {
        document.getElementById('formSection').style.display = 'none';
        const exp = document.getElementById('expiradoSection');
        exp.style.display = '';
        document.getElementById('exp-nome').textContent = 'cliente';
        document.querySelector('#expiradoSection .prop-header h1').textContent = 'Proposta não encontrada';
        document.querySelector('#expiradoSection .prop-header .sub').textContent = 'Esta proposta não existe ou foi removida';
        document.getElementById('exp-consultor').style.display = 'none';
        return;
      }
      const row = arr[0];
      d = row.dados;
      d.dataEmissao = row.created_at;
      d.codigo = row.codigo;
      codigoSupabase = row.codigo;
      dataEmissao = new Date(row.created_at);

      // Registrar acesso APENAS se for cliente (não inflar contador com vendedor revisitando)
      if (!vendedor) {
        supaRpc('registrar_acesso', { p_codigo: p }).catch(e => console.error(e));
      }
    } else {
      // Legado: base64 (links antigos sem banco)
      const json = decodeURIComponent(escape(atob(decodeURIComponent(p))));
      d = JSON.parse(json);
      if (!d.nome || !d.item || !d.tab) return;
      dataEmissao = d.dataEmissao ? new Date(d.dataEmissao) : new Date();
    }

    // Vendedor: ignora expiração (precisa reaproveitar propostas antigas)
    const diasPassados = (new Date() - dataEmissao) / (1000 * 60 * 60 * 24);
    if (diasPassados > 7 && !vendedor) {
      mostrarExpirado(d);
      return;
    }

    dadosAtual = d;
    // viaLink = true (esconde botões) só pro cliente. Vendedor vê tudo.
    renderProposta(d, !vendedor);
  } catch (e) {
    console.error('Erro ao carregar proposta da URL:', e);
  }
}

function mostrarExpirado(d) {
  document.getElementById('formSection').style.display = 'none';
  document.getElementById('propostaSection').style.display = 'none';
  const exp = document.getElementById('expiradoSection');
  exp.style.display = '';

  document.getElementById('exp-nome').textContent = d.nome || '';

  const consultorBox = document.getElementById('exp-consultor');
  if (d.consultor) {
    consultorBox.style.display = '';
    document.getElementById('exp-consultor-nome').textContent = d.consultor;
    document.getElementById('exp-consultor-tel').style.display = 'none';
  } else {
    consultorBox.style.display = 'none';
  }
}

window.addEventListener('DOMContentLoaded', carregarDeURL);

// ============= HISTÓRICO =============
function formatDataBR(iso) {
  if (!iso) return '-';
  const d = new Date(iso);
  return d.toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit' });
}

function escapeHtml(s) {
  if (s == null) return '';
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

async function abrirHistorico() {
  document.getElementById('formSection').style.display = 'none';
  document.getElementById('propostaSection').style.display = 'none';
  document.getElementById('expiradoSection').style.display = 'none';
  document.getElementById('historicoSection').style.display = '';
  window.scrollTo({ top: 0, behavior: 'smooth' });

  const tbody = document.getElementById('historico-tbody');
  const statsBox = document.getElementById('historico-stats');
  tbody.innerHTML = '<tr><td colspan="17" class="historico-vazio">Carregando...</td></tr>';
  statsBox.innerHTML = '';

  try {
    const rows = await supaGet('propostas?select=*&order=created_at.desc&limit=500');
    if (!rows || rows.length === 0) {
      tbody.innerHTML = '<tr><td colspan="17" class="historico-vazio">Nenhuma proposta gerada ainda. Volte e gere a primeira!</td></tr>';
      return;
    }

    const totalAcessos = rows.reduce((s, r) => s + (r.acessos || 0), 0);
    const totalLink = rows.reduce((s, r) => s + (r.enviado_link || 0), 0);
    const totalWpp = rows.reduce((s, r) => s + (r.enviado_wpp || 0), 0);
    const totalKwp = rows.reduce((s, r) => s + Number(r.kwp || 0), 0);
    const consultoresUnicos = new Set(rows.map(r => r.consultor_nome).filter(Boolean)).size;
    const clientesUnicos = new Set(rows.map(r => r.cliente_nome).filter(Boolean)).size;

    statsBox.innerHTML = `
      <div class="historico-stat"><div class="lbl">Propostas</div><div class="val">${rows.length}</div></div>
      <div class="historico-stat"><div class="lbl">Clientes</div><div class="val">${clientesUnicos}</div></div>
      <div class="historico-stat"><div class="lbl">Consultores</div><div class="val">${consultoresUnicos}</div></div>
      <div class="historico-stat"><div class="lbl">kWp totais</div><div class="val">${totalKwp.toFixed(1)}</div></div>
      <div class="historico-stat"><div class="lbl">🔗 Links enviados</div><div class="val">${totalLink}</div></div>
      <div class="historico-stat"><div class="lbl">📱 WhatsApp enviados</div><div class="val">${totalWpp}</div></div>
      <div class="historico-stat"><div class="lbl">Aberturas pelo cliente</div><div class="val">${totalAcessos}</div></div>
    `;

    tbody.innerHTML = rows.map(r => {
      const l = r.enviado_link || 0;
      const w = r.enviado_wpp || 0;
      let enviadoCell;
      if (l > 0 && w > 0) enviadoCell = `<span title="Link e WhatsApp">🔗${l} 📱${w}</span>`;
      else if (l > 0) enviadoCell = `<span title="Apenas link">🔗 ${l}x</span>`;
      else if (w > 0) enviadoCell = `<span title="Apenas WhatsApp">📱 ${w}x</span>`;
      else enviadoCell = '<span style="color:#aaa">-</span>';

      return `
      <tr>
        <td class="codigo">${escapeHtml(r.codigo)}</td>
        <td>${formatDataBR(r.created_at)}</td>
        <td>${escapeHtml(r.cliente_nome) || '-'}</td>
        <td>${escapeHtml(r.consultor_nome) || '-'}</td>
        <td>${escapeHtml(r.cliente_cidade) || '-'}</td>
        <td>${escapeHtml(r.cliente_uf) || '-'}</td>
        <td>${r.kwp || '-'}</td>
        <td>${r.geracao_kwh ? r.geracao_kwh + ' kWh' : '-'}</td>
        <td>${r.qtd_placas || '-'}</td>
        <td>${escapeHtml(r.inversor) || '-'}</td>
        <td>${r.qtd_inversor || '-'}</td>
        <td>${escapeHtml(r.telhado) || '-'}</td>
        <td>${escapeHtml(r.fase) || '-'}</td>
        <td>${enviadoCell}</td>
        <td><strong>${r.acessos || 0}</strong></td>
        <td>${r.ultimo_acesso ? formatDataBR(r.ultimo_acesso) : '<span style="color:#aaa">nunca</span>'}</td>
        <td>
          <div class="acoes-mini">
            <button class="copiar" onclick="copiarLinkCodigo('${escapeHtml(r.codigo)}')">🔗</button>
            <button onclick="abrirProposta('${escapeHtml(r.codigo)}')">Abrir</button>
          </div>
        </td>
      </tr>
    `;}).join('');
  } catch (e) {
    console.error(e);
    tbody.innerHTML = `<tr><td colspan="17" class="historico-vazio">Erro ao carregar: ${escapeHtml(e.message)}</td></tr>`;
  }
}

function voltarDoHistorico() {
  document.getElementById('historicoSection').style.display = 'none';
  document.getElementById('formSection').style.display = '';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function copiarLinkCodigo(codigo) {
  const link = `${window.location.origin}${window.location.pathname}?p=${codigo}`;
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(link).then(
      () => showToast(`🔗 Link ${codigo} copiado!`),
      () => fallbackCopy(link)
    );
  } else {
    fallbackCopy(link);
  }
}

function abrirProposta(codigo) {
  window.location.href = `${window.location.pathname}?p=${codigo}`;
}

// ============= PDF =============
function gerarPDF() {
  window.print();
}

// ============= WHATSAPP =============
async function copiarWhatsApp() {
  if (!dadosAtual) return;
  const d = dadosAtual;

  // Tracking — salva proposta se ainda não tem código + marca envio WhatsApp
  garantirCodigo()
    .then(cod => supaRpc('marcar_enviado_wpp', { p_codigo: cod }))
    .catch(e => console.error('Tracking falhou:', e));

  const linhasCli = [`👤 *Cliente:* ${d.nome}`];
  if (d.cidade)  linhasCli.push(`📍 *Cidade:* ${d.cidade}`);
  if (d.fase)    linhasCli.push(`⚡ *Ligação:* ${d.fase}`);
  if (d.telhado) linhasCli.push(`🏠 *Telhado:* ${d.telhado}`);

  const txt =
`☀️ *PROPOSTA DE ENERGIA SOLAR* ☀️

${linhasCli.join('\n')}

━━━━━━━━━━━━━━━━━━
🔋 *SISTEMA*
• Módulos: ${d.item.n}x ${d.tab.mod}
• Inversor: ${d.qtdInv}x ${d.tab.inv}
• Potência instalada: ${d.item.kwp.toFixed(1)} kWp
• Geração estimada: ${fmtN(d.item.g)} kWh/mês
• Área no telhado: ~${d.areaReal} m²

━━━━━━━━━━━━━━━━━━
📦 *INCLUSO NO PROJETO*
✅ Estruturas de fixação
✅ Cabeamento completo
✅ Caixa de corrente alternada
✅ Aterramento do sistema
✅ Homologação na concessionária
✅ Projeto conforme Lei 14.300/22
✅ Instalação conforme normas ABNT
✅ Monitoramento do sistema

━━━━━━━━━━━━━━━━━━
🛡️ *GARANTIAS*
• Módulos: 25 anos de performance | 15 anos contra defeitos
• Inversor: ${d.garInv} anos
• Mão de obra: 1 ano

━━━━━━━━━━━━━━━━━━
📈 *RETORNO FINANCEIRO*
• Economia mensal: ~R$ ${fmtN(d.economia)}/mês
• Economia em 25 anos: ~R$ ${fmtN(d.economia25)}
• Payback estimado: ~${d.payback} anos

━━━━━━━━━━━━━━━━━━
💰 *Investimento (Valor Financiado): R$ ${fmt(d.precoOrcamento)}*
💎 *Condição especial à vista: R$ ${fmt(d.precoVista)}*

💳 *Formas de pagamento no cartão:*
• 10x: R$ ${fmt(d.parc10x)}/mês
• 18x: R$ ${fmt(d.parc18x)}/mês

${d.consultor ? `━━━━━━━━━━━━━━━━━━\n👤 *Atendimento:* ${d.consultor}\n` : ''}
_Proposta válida por 7 dias_`;

  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(txt).then(
      () => showToast('✅ Copiado! Cole no WhatsApp'),
      () => fallbackCopy(txt)
    );
  } else {
    fallbackCopy(txt);
  }
}

function fallbackCopy(txt) {
  const ta = document.createElement('textarea');
  ta.value = txt;
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try {
    document.execCommand('copy');
    showToast('✅ Copiado! Cole no WhatsApp');
  } catch (e) {
    showToast('❌ Não foi possível copiar');
  }
  document.body.removeChild(ta);
}

// ============= PWA — Service Worker =============
// SW desativado dentro do dashboard pra não conflitar com SW principal.
// Quando rodando standalone, sw.js fica disponível em /gerador/sw.js mas não é registrado aqui.
</script>

